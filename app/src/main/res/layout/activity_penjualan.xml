<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="50dp"
        android:background="@color/white"
        app:layout_constraintTop_toTopOf="parent">
        <ImageView android:id="@+id/btnBack" android:src="@drawable/ic_arrow_back" app:tint="@color/black" android:layout_width="24dp" android:layout_height="24dp"/>
        <TextView android:text="Penjualan" android:textSize="20sp" android:textStyle="bold" android:textColor="#00BCD4" android:layout_marginStart="16dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/topCards"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:weightSum="3"
        app:layout_constraintTop_toBottomOf="@id/headerLayout">

        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_weight="1.2"
            android:layout_height="80dp"
            app:cardCornerRadius="12dp"
            android:layout_margin="4dp">
            <LinearLayout android:orientation="vertical" android:padding="10dp" android:gravity="center" android:layout_width="match_parent" android:layout_height="match_parent" android:background="#E0E0E0">
                <TextView android:text="Total" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:id="@+id/tvTopTotal" android:text="Rp 0" android:textStyle="bold" android:textSize="14sp" android:layout_marginTop="4dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_weight="0.8"
            android:layout_height="80dp"
            app:cardCornerRadius="12dp"
            android:layout_margin="4dp">
            <LinearLayout android:orientation="vertical" android:padding="10dp" android:gravity="center" android:layout_width="match_parent" android:layout_height="match_parent" android:background="#E0E0E0">
                <TextView android:text="Quantity" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:id="@+id/tvTopQty" android:text="0" android:textStyle="bold" android:textSize="18sp" android:layout_marginTop="4dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardPelanggan"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="80dp"
            app:cardCornerRadius="12dp"
            android:layout_margin="4dp">
            <LinearLayout android:orientation="vertical" android:padding="10dp" android:gravity="center" android:layout_width="match_parent" android:layout_height="match_parent" android:background="#E0E0E0">
                <TextView android:text="Pelanggan" android:textSize="12sp" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <ImageView android:src="@drawable/ic_menu_pelanggan" android:layout_width="24dp" android:layout_height="24dp" android:layout_marginTop="4dp"/>
                <TextView android:id="@+id/tvNamaPelanggan" android:text="Umum" android:textSize="11sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/middleSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toBottomOf="@id/topCards">

        <TextView android:id="@+id/tvNoFaktur" android:text="No Faktur : -" android:textStyle="bold" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content"/>

        <Button
            android:id="@+id/btnTambahBarang"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:backgroundTint="#76FF03"
            android:text="Tambah Barang"
            android:textColor="#000"
            android:textStyle="bold"
            tools:ignore="TouchTargetSizeCheck" />
    </LinearLayout>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_margin="12dp"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="#FFD54F"
        app:layout_constraintTop_toBottomOf="@id/middleSection"
        app:layout_constraintBottom_toTopOf="@id/bottomSummary">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="8dp">

            <LinearLayout android:orientation="horizontal" android:weightSum="5" android:layout_width="match_parent" android:layout_height="wrap_content">
                <TextView android:text="Item" android:textStyle="bold" android:layout_weight="1.5" android:layout_width="0dp" android:layout_height="wrap_content"/>
                <TextView android:text="Qty" android:textStyle="bold" android:gravity="center" android:layout_weight="0.5" android:layout_width="0dp" android:layout_height="wrap_content"/>
                <TextView android:text="Harga" android:textStyle="bold" android:gravity="end" android:layout_weight="1.5" android:layout_width="0dp" android:layout_height="wrap_content"/>
                <TextView android:text="Total" android:textStyle="bold" android:gravity="end" android:layout_weight="1.5" android:layout_width="0dp" android:layout_height="wrap_content"/>
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvCart"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="8dp"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:id="@+id/bottomSummary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:cardCornerRadius="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="4dp">
                <TextView android:text="Tanggal" android:layout_width="100dp" android:layout_height="wrap_content"/>
                <TextView android:id="@+id/tvTanggal" android:text="08/02/2026" android:background="#E0E0E0" android:padding="4dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <Space android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content"/>
                <TextView android:text="Sub Total" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:id="@+id/tvSubTotal" android:text="0" android:gravity="end" android:background="#E0E0E0" android:padding="4dp" android:width="100dp" android:layout_marginStart="8dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="4dp">
                <TextView android:text="Pembayaran" android:layout_width="100dp" android:layout_height="wrap_content"/>

                <Spinner
                    android:id="@+id/spinnerPayment"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="#E0E0E0"
                    tools:ignore="TouchTargetSizeCheck" />
                <Space android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content"/>
                <TextView android:text="Diskon" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:id="@+id/tvDiskonVal" android:text="0%" android:gravity="end" android:background="#E0E0E0" android:padding="4dp" android:width="100dp" android:layout_marginStart="8dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="4dp">
                <TextView android:text="Dibayar" android:layout_width="100dp" android:layout_height="wrap_content"/>

                <EditText
                    android:id="@+id/etDibayar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="#E0E0E0"
                    android:hint="Input"
                    android:inputType="numberDecimal"
                    android:minWidth="100dp"
                    android:padding="4dp"
                    tools:ignore="TouchTargetSizeCheck" />
                <Space android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content"/>
                <TextView android:text="Total" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:id="@+id/tvGrandTotal" android:text="0" android:textStyle="bold" android:gravity="end" android:background="#E0E0E0" android:padding="4dp" android:width="100dp" android:layout_marginStart="8dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp">
                <TextView android:text="Kembali" android:layout_width="100dp" android:layout_height="wrap_content"/>
                <TextView android:id="@+id/tvKembali" android:text="0" android:background="#E0E0E0" android:padding="4dp" android:minWidth="100dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <Space android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content"/>

                <Button
                    android:id="@+id/btnPrint"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:backgroundTint="#76FF03"
                    android:text="Print"
                    android:textColor="#000"
                    tools:ignore="TouchTargetSizeCheck" />
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>
</androidx.constraintlayout.widget.ConstraintLayout>